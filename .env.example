# Auth — pick a strong password
SITE_PASSWORD=your-password-here
AUTH_SECRET=random-32-char-string-change-this

# Google AI (image generation — Nano Banana + Imagen 4)
# Get your key at https://aistudio.google.com
GOOGLE_AI_API_KEY=your-google-ai-api-key

# Hermes API (local — auto-detected if running on same machine)
HERMES_API_URL=http://localhost:8642
HERMES_MODEL=hermes-agent

# Data directory for SQLite DB + file uploads
DATA_DIR=/absolute/path/to/hermes-web/data
